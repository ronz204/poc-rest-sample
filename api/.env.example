# ==========================================
# Application Config
# ==========================================
APP_PORT=3000
APP_VERSION="1.0.0"
APP_NAME="Hexagon Service"

# ==========================================
# PostgreSQL Config
# ==========================================
POSTGRES_DB=hexagon
POSTGRES_USER=hexagon
POSTGRES_SCHEMA=poc

POSTGRES_PORT=5432
POSTGRES_HOST=localhost
POSTGRES_PASSWORD=<secure_password>
POSTGRES_URL="postgres://hexagon:password@localhost:5432/hexagon"

# ==========================================
# Security Config
# ==========================================
SECRET_KEY="sample_secret_key"
CORS_ORIGIN="http://localhost:5173,http://localhost:3000"