enum FlagState {
  on
  off

  @@schema("engine")
}

model Flag {
  id    String @id @default(uuid()) @db.Uuid
  key   String @unique @db.VarChar(100)
  short String @default("")

  rules Rule[]

  state   FlagState   @default(off)
  default RuleOutcome @default(inactive)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([key])
  @@map("flags")
  @@schema("engine")
}
