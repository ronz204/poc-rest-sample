enum RuleOutcome {
  on
  off
  rollout

  @@schema("engine")
}

model Flag {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  key         String   @unique @db.VarChar(100)
  name        String   @db.VarChar(255)
  description String?  @db.Text
  enabled     Boolean  @default(false)
  default     Boolean  @default(false)
  createdAt   DateTime @default(now()) @db.Timestamptz()
  updatedAt   DateTime @updatedAt @db.Timestamptz()

  rules Rule[]

  @@map("flags")
  @@schema("engine")
}

model Segment {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  key        String   @unique @db.VarChar(100)
  name       String   @db.VarChar(255)
  conditions Json
  createdAt  DateTime @default(now()) @db.Timestamptz()
  updatedAt  DateTime @updatedAt @db.Timestamptz()

  rules Rule[]

  @@map("segments")
  @@schema("engine")
}

model Rule {
  id         String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  flagId     String      @db.Uuid
  segmentId  String?     @db.Uuid
  priority   Int
  conditions Json?
  outcome    RuleOutcome
  rollout    Int?        @db.SmallInt
  createdAt  DateTime    @default(now()) @db.Timestamptz()

  flag    Flag     @relation(fields: [flagId], references: [id], onDelete: Cascade)
  segment Segment? @relation(fields: [segmentId], references: [id], onDelete: SetNull)

  @@index([flagId, priority])
  @@map("rules")
  @@schema("engine")
}
